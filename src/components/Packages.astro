---
import { monthlyPlans } from '../data/plans.js';

const packages = monthlyPlans;
---

<section id="section-packages" class="section bg-white" aria-label="Paquetes de nutrición">
  <div class="container">
    <p class="label">Asesoría nutricional</p>
    <h2 class="title" style="margin-bottom: 0.75rem;">Todos los planes</h2>
    <p class="subtitle" style="margin-bottom: 3rem;">
      La diferencia entre planes es la frecuencia de acompañamiento.
      Si aún no sabes cuál elegir, más abajo hay una opción para ti.
    </p>

    <div class="packages-grid">
      {packages.map(pkg => (
        <article class={`pkg-card${pkg.highlight ? ' pkg-card--featured' : ''}`}>

          {pkg.badge && (
            <span class={`pkg-badge${pkg.highlight ? ' pkg-badge--gold' : ' pkg-badge--outline'}`}>
              {pkg.badge}
            </span>
          )}
          {!pkg.badge && <span class="pkg-badge-spacer" aria-hidden="true" />}

          <h3 class="pkg-name">{pkg.name}</h3>
          <p class="pkg-tagline">{pkg.tagline}</p>

          <div class="pkg-price">
            <span class="pkg-price__amount">S/{pkg.price}</span>
            <span class="pkg-price__period">/mes</span>
          </div>

          <div class="pkg-freq-pill">{pkg.freq}</div>

          <!-- Sesiones individuales -->
          <ul class="pkg-features">
            {pkg.sessions.map(s => (
              <li class={`pkg-feature${!s.included ? ' pkg-feature--off' : ''}`}>
                <span class="pkg-feature__icon" aria-hidden="true">
                  {s.included ? '✓' : '—'}
                </span>
                <span class="pkg-feature__text">
                  {s.count && <strong>{s.count} </strong>}{s.label}
                  {s.note && s.included && <span class="pkg-feature__note">{s.note}</span>}
                </span>
              </li>
            ))}
          </ul>

          <!-- Acompañamiento continuo -->
          <p class="pkg-section-label">Acompañamiento continuo</p>
          <ul class="pkg-features">
            {pkg.continuous.map(f => (
              <li class={`pkg-feature${!f.included ? ' pkg-feature--off' : ''}`}>
                <span class="pkg-feature__icon" aria-hidden="true">
                  {f.included ? (f.star ? '★' : '✓') : '—'}
                </span>
                <span class="pkg-feature__text">
                  {f.label}
                  {f.note && f.included && <span class="pkg-feature__note">{f.note}</span>}
                </span>
              </li>
            ))}
          </ul>

          <!-- Programas -->
          <div class="pkg-programs">
            <p class="pkg-section-label">Programas</p>
            {pkg.programs ? (
              <ul class="pkg-program-list">
                {pkg.programs.map(p => (
                  <li class="pkg-program-item">
                    <span class="pkg-program__label">{p.label}</span>
                    <span class="pkg-program__prices">
                      <strong>{p.total}</strong>
                      <span class="pkg-program__per">{p.perMes}</span>
                    </span>
                  </li>
                ))}
              </ul>
            ) : (
              <p class="pkg-programs-note">{pkg.programsNote}</p>
            )}
          </div>

          <!-- CTA -->
          <a
            href={`/checkout/${pkg.id}`}
            class={`pkg-cta${pkg.highlight ? ' pkg-cta--featured' : ''}`}
            data-section="paquetes"
            data-pkg={pkg.name}
            aria-label={`Quiero el plan ${pkg.name}`}
          >
            Quiero este plan →
          </a>
        </article>
      ))}
    </div>

    <p class="packages-tagline">
      El mismo método. Más acompañamiento para que
      <strong>el proceso se adapte a tu vida</strong>, no al revés.
    </p>

    <div class="packages-note">
      <p>
        ¿No sabes cuál elegir? No hay problema.
        Más abajo encontrarás la <strong>Evaluación Nutricional de S/80</strong> —
        una consulta previa que te ayuda a definir el plan correcto para tu caso.
      </p>
    </div>
  </div>
</section>

<style>
.bg-white { background: var(--white); }

/* Grid */
.packages-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1rem;
  margin-bottom: 2rem;
  align-items: start;
}

/* Card */
.pkg-card {
  border: 1px solid #e5e5e5;
  border-radius: 12px;
  padding: 1.5rem 1.25rem;
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  transition: border-color var(--transition), box-shadow var(--transition);
}

.pkg-card:hover {
  border-color: var(--gold);
  box-shadow: 0 4px 20px rgba(212,168,67,0.1);
}

.pkg-card--featured {
  border-color: var(--gold);
  background: var(--black);
  box-shadow: 0 8px 32px rgba(212,168,67,0.15);
}

/* Badges */
.pkg-badge-spacer { display: block; height: 1.5rem; }

.pkg-badge {
  display: inline-block;
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  padding: 0.2rem 0.75rem;
  border-radius: 20px;
  align-self: flex-start;
}

.pkg-badge--gold {
  background: var(--gold);
  color: var(--black);
}

.pkg-badge--outline {
  border: 1px solid #ccc;
  color: #888;
  background: transparent;
}

.pkg-card--featured .pkg-badge--gold { background: var(--gold); }

/* Name & tagline */
.pkg-name {
  font-size: 1.2rem;
  font-weight: 900;
  color: var(--black);
  letter-spacing: -0.3px;
  line-height: 1.1;
}

.pkg-card--featured .pkg-name { color: var(--white); }

.pkg-tagline {
  font-size: 0.78rem;
  color: var(--gray-mid);
  margin-top: -0.4rem;
}

.pkg-card--featured .pkg-tagline { color: #888; }

/* Price */
.pkg-price { line-height: 1; }

.pkg-price__amount {
  font-size: 2.25rem;
  font-weight: 900;
  color: var(--gold);
  letter-spacing: -1px;
}

.pkg-price__period {
  font-size: 0.8rem;
  color: var(--gray-mid);
  margin-left: 0.1rem;
}

/* Frequency pill */
.pkg-freq-pill {
  display: inline-flex;
  align-self: flex-start;
  font-size: 0.68rem;
  font-weight: 700;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: var(--gold);
  border: 1px solid var(--gold);
  padding: 0.2rem 0.625rem;
  border-radius: 20px;
}

/* Section label */
.pkg-section-label {
  font-size: 0.62rem;
  font-weight: 700;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: #aaa;
  margin-top: 0.25rem;
  padding-top: 0.75rem;
  border-top: 1px solid #eeeeee;
}

.pkg-card--featured .pkg-section-label { border-color: #222; }

/* Features */
.pkg-features {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  margin: 0;
}

.pkg-feature {
  display: flex;
  align-items: flex-start;
  gap: 0.5rem;
  font-size: 0.82rem;
  line-height: 1.4;
  color: var(--gray-dark);
}

.pkg-card--featured .pkg-feature { color: #ccc; }

.pkg-feature--off {
  opacity: 0.35;
}

.pkg-feature__icon {
  flex-shrink: 0;
  color: var(--gold);
  font-size: 0.8rem;
  width: 12px;
  margin-top: 0.1em;
}

.pkg-feature--off .pkg-feature__icon { color: #aaa; }

.pkg-feature__text { flex: 1; }

.pkg-feature__note {
  display: block;
  font-size: 0.72rem;
  color: #aaa;
  margin-top: 0.1rem;
}

.pkg-card--featured .pkg-feature__note { color: #666; }

/* Programs */
.pkg-programs { margin-top: auto; }

.pkg-program-list {
  display: flex;
  flex-direction: column;
  gap: 0.375rem;
}

.pkg-program-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 0.8rem;
  gap: 0.5rem;
}

.pkg-program__label {
  color: var(--gray-mid);
}

.pkg-program__prices {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 0.1rem;
}

.pkg-program__prices strong {
  font-size: 0.85rem;
  color: var(--black);
}

.pkg-card--featured .pkg-program__prices strong { color: var(--white); }

.pkg-program__per {
  font-size: 0.68rem;
  color: var(--gold);
}

.pkg-programs-note {
  font-size: 0.75rem;
  color: #aaa;
  font-style: italic;
}

/* CTA */
.pkg-cta {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 1rem;
  padding: 0.75rem 1rem;
  background: var(--gray-light);
  color: var(--black);
  font-weight: 700;
  font-size: 0.82rem;
  text-align: center;
  border-radius: var(--radius);
  transition: background var(--transition), color var(--transition);
  min-height: 44px;
}

.pkg-cta:hover { background: var(--gold); color: var(--black); }

.pkg-cta--featured {
  background: var(--gold);
  color: var(--black);
}

.pkg-cta--featured:hover { background: var(--gold-dark); }

/* Tagline */
.packages-tagline {
  text-align: center;
  font-size: 0.9rem;
  color: var(--gray-mid);
  margin-bottom: 1.5rem;
  line-height: 1.6;
}

.packages-tagline strong { color: var(--black); }

/* Note */
.packages-note {
  padding: 1.5rem 2rem;
  background: var(--gray-light);
  border-radius: 10px;
  text-align: center;
}

.packages-note p {
  font-size: 0.92rem;
  color: var(--gray-dark);
  line-height: 1.65;
}

/* Responsive */
@media (max-width: 1100px) {
  .packages-grid { grid-template-columns: repeat(2, 1fr); }
}

@media (max-width: 600px) {
  .packages-grid { grid-template-columns: 1fr; }
}
</style>
