---
import { WA_FALLBACK_URL } from '../config.js';
---

<footer id="section-footer" class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <p class="footer__logo">AJL Nutrición</p>
      <p class="footer__tagline">Estructura para tu vida real.</p>
      <p class="footer__location">Lima, Perú</p>
    </div>

    <div class="footer__links">
      <a
        href={WA_FALLBACK_URL}
        class="btn-primary footer__wa-btn"
        data-wa-section="footer"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Contactar por WhatsApp"
      >
        <!-- WhatsApp icon -->
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        WhatsApp
      </a>
    </div>

    <div class="footer__legal">
      <p class="footer__copy">
        © {new Date().getFullYear()} AJL Nutrición. Todos los derechos reservados.
      </p>
      <p class="footer__privacy">
        <a href="/politica-de-privacidad" class="footer__legal-link">Política de privacidad</a>
        ·
        <a href="/terminos" class="footer__legal-link">Términos</a>
      </p>
      <p class="footer__disclaimer">
        Los resultados individuales varían según el caso y la constancia de cada paciente.
        AJL Nutrición no garantiza resultados específicos de pérdida de peso.
      </p>
    </div>
  </div>
</footer>

<style>
.footer {
  background: var(--black);
  color: var(--white);
  padding-block: 3.5rem;
  border-top: 1px solid #1a1a1a;
}

.footer__inner {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: start;
  gap: 2.5rem;
}

.footer__brand {
  display: flex;
  flex-direction: column;
  gap: 0.375rem;
}

.footer__logo {
  font-size: 1.2rem;
  font-weight: 900;
  color: var(--gold);
  letter-spacing: -0.3px;
}

.footer__tagline {
  font-size: 0.85rem;
  color: #888;
  font-style: italic;
}

.footer__location {
  font-size: 0.75rem;
  color: #555;
  letter-spacing: 0.5px;
}

.footer__links {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1rem;
}

.footer__wa-btn {
  gap: 0.625rem;
}

.footer__legal {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  text-align: right;
}

.footer__copy {
  font-size: 0.78rem;
  color: #555;
}

.footer__privacy {
  font-size: 0.78rem;
  color: #555;
  display: flex;
  gap: 0.5rem;
  justify-content: flex-end;
}

.footer__legal-link {
  color: #666;
  transition: color var(--transition);
}

.footer__legal-link:hover { color: var(--gold); }

.footer__disclaimer {
  font-size: 0.7rem;
  color: #444;
  line-height: 1.5;
  max-width: 280px;
  margin-left: auto;
}

@media (max-width: 768px) {
  .footer__inner {
    grid-template-columns: 1fr;
    text-align: center;
  }

  .footer__legal { text-align: center; }
  .footer__privacy { justify-content: center; }
  .footer__disclaimer { margin-inline: auto; }
}
</style>
